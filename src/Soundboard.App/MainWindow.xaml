<Window x:Class="Soundboard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Soundboard"
        Height="720" Width="1040"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource BgBrush}"
        PreviewKeyDown="Window_PreviewKeyDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      ResizeBorderThickness="6"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource BgBrush}"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Unified title bar (Discord / Chrome style) -->
        <Grid Grid.Row="0" Background="{StaticResource BgBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                <Border Width="20" Height="20" CornerRadius="5" ClipToBounds="True" Margin="0,0,10,0">
                    <Image Source="Assets/soundboard-icon.png" Stretch="UniformToFill"/>
                </Border>
                <TextBlock Text="Soundboard" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource WindowChromeButton}" Content="&#xE921;" FontFamily="Segoe MDL2 Assets"
                        Click="MinimizeClick" ToolTip="Minimize"/>
                <Button Style="{StaticResource WindowChromeButton}" Content="&#xE922;" FontFamily="Segoe MDL2 Assets"
                        Click="MaximizeClick" ToolTip="Maximize"/>
                <Button Style="{StaticResource WindowCloseButton}" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                        Click="CloseClick" ToolTip="Close"/>
            </StackPanel>
        </Grid>

        <!-- App content -->
        <Grid Grid.Row="1" Margin="20,8,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="Mic + clips → virtual mic" FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <Border Background="#121820" CornerRadius="14" Padding="12,6" Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                    </Border>
                    <Button Content="Start" Style="{StaticResource SuccessButton}" Margin="0,0,8,0"
                            Command="{Binding StartEngineCommand}"/>
                    <Button Content="Stop" Style="{StaticResource DangerButton}"
                            Command="{Binding StopEngineCommand}"/>
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Input &amp; monitoring" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <TextBlock Text="Input microphone" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding CaptureDevices}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="FriendlyName"
                                  SelectedValue="{Binding SelectedCaptureDeviceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <CheckBox Content="Hear sounds on my speakers/headphones"
                                  IsChecked="{Binding HearSoundsLocally, Mode=TwoWay}"
                                  Margin="0,12,0,8"/>
                        <TextBlock Text="Local monitor device" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding RenderDevices}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="FriendlyName"
                                  SelectedValue="{Binding SelectedMonitorDeviceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding HearSoundsLocally}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Virtual mic output" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <TextBlock Text="Output (use CABLE Input — not speakers)" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding RenderDevices}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="FriendlyName"
                                  SelectedValue="{Binding SelectedRenderDeviceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="{Binding OutputWarningText}" Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap" Margin="0,8,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowOutputWarning}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding DiscordHintText}" TextWrapping="Wrap" Margin="0,6,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                        <Button Content="Install VB-CABLE" Margin="0,12,0,0" HorizontalAlignment="Left"
                                Command="{Binding InstallVirtualCableCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowInstallVirtualCableButton}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,4">
                        <TextBlock Text="Your sounds" FontSize="16" FontWeight="SemiBold" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Content="Import sound" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                    Command="{Binding ImportSoundCommand}"/>
                            <Button Content="Refresh devices" Style="{StaticResource GhostButton}"
                                    Command="{Binding RefreshDevicesCommand}"/>
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="1" Padding="12" CornerRadius="12" Background="#2A2418" BorderBrush="#5C4D1F" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCapturingHotkey}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <DockPanel>
                            <Button Content="Cancel" Style="{StaticResource GhostButton}" DockPanel.Dock="Right"
                                    Padding="12,6" Margin="8,0,0,0"
                                    Command="{Binding CancelHotkeyCaptureCommand}"/>
                            <TextBlock Text="{Binding HotkeyCapturePrompt}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <DataGrid Grid.Row="3"
                              ItemsSource="{Binding Sounds}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"
                                                Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="2*"/>
                            <DataGridTextColumn Header="Hotkey" Binding="{Binding Hotkey}" Width="*" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Volume" Width="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,0" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="44"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider Grid.Column="0"
                                                    Minimum="0" Maximum="100"
                                                    Value="{Binding VolumePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding VolumeLabel}"
                                                       VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Actions" Width="340">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Play" Style="{StaticResource SmallPrimaryButton}" Margin="0,0,6,0"
                                                    Command="{Binding DataContext.PlaySoundCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Bind" Style="{StaticResource SmallButton}" Margin="0,0,6,0"
                                                    Command="{Binding DataContext.BindHotkeyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Clear" Style="{StaticResource SmallButton}" Margin="0,0,6,0"
                                                    Command="{Binding DataContext.ClearHotkeyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Delete" Style="{StaticResource SmallDangerButton}"
                                                    Command="{Binding DataContext.DeleteSoundCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <TextBlock Grid.Row="5" Margin="4,14,4,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"
                       Text="Tip: Bind hotkey → press combo. Output = CABLE Input, Discord mic = CABLE Output."/>
        </Grid>
        </Grid>
    </Border>
</Window>
